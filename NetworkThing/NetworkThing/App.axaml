<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:NetworkThing"
             x:Class="NetworkThing.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Styles/Styles.axaml"/>
    </Application.Styles>
    
    <Application.Resources>
        <FontFamily x:Key="Phosphor">
            avares://NetworkThing/Assets/Fonts#Phosphor-Bold
        </FontFamily>
    </Application.Resources>
</Application>